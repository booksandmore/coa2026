<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#5b4ae0">
<title>Study Flashcards</title>
<style>
  /* ============================================================
     Minimal flashcard styling — warm, light, no external fonts
     ============================================================ */
  :root {
    --bg: #faf9f6;
    --surface: #ffffff;
    --text: #1a1a1d;
    --muted: #7a7d85;
    --primary: #5b4ae0;
    --primary-soft: #efedfc;
    --success: #16a34a;
    --success-soft: #e7f6ec;
    --border: #ececef;
    --shadow: 0 1px 2px rgba(20,20,30,.04), 0 8px 28px rgba(20,20,30,.06);
    --shadow-hover: 0 1px 2px rgba(20,20,30,.04), 0 14px 36px rgba(20,20,30,.09);
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0c0d12;
      --surface: #16181f;
      --text: #ececf1;
      --muted: #8d909a;
      --primary: #8b7cff;
      --primary-soft: #1f1c3a;
      --success-soft: #14271c;
      --border: #232631;
      --shadow: 0 1px 2px rgba(0,0,0,.4), 0 12px 32px rgba(0,0,0,.4);
      --shadow-hover: 0 1px 2px rgba(0,0,0,.5), 0 18px 40px rgba(0,0,0,.5);
    }
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  .app {
    max-width: 620px;
    margin: 0 auto;
    padding: 32px 20px 56px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  header { text-align: center; margin-bottom: 24px; }
  header h1 {
    font-size: 22px;
    font-weight: 600;
    margin: 0 0 6px;
    letter-spacing: -0.012em;
  }
  header p {
    margin: 0;
    color: var(--muted);
    font-size: 13.5px;
    letter-spacing: 0.005em;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12.5px;
    color: var(--muted);
    margin: 22px 4px 10px;
    letter-spacing: 0.02em;
  }
  .meta .pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 4px 10px;
  }
  .meta b { color: var(--text); font-weight: 600; }
  .progress-bar {
    height: 4px;
    background: var(--border);
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 24px;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--success) 0%, #5fc97a 100%);
    width: 0%;
    transition: width .35s cubic-bezier(.4,.0,.2,1);
  }

  /* Card — the minimal touches */
  .card-stage {
    perspective: 1600px;
    flex: 1;
    min-height: 360px;
    display: flex;
    align-items: center;
    margin-bottom: 22px;
  }
  .card {
    width: 100%;
    height: 360px;
    position: relative;
    transform-style: preserve-3d;
    transition: transform .55s cubic-bezier(.22,.61,.36,1);
    cursor: pointer;
  }
  .card.flipped { transform: rotateY(180deg); }
  .face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background: var(--surface);
    border-radius: 22px;
    box-shadow: var(--shadow);
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    border: 1px solid var(--border);
    overflow: hidden;
    transition: box-shadow .25s ease;
  }
  .card:hover .face { box-shadow: var(--shadow-hover); }
  /* subtle accent stripe at the top */
  .face::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--primary) 0%, #8b7cff 100%);
    opacity: .85;
  }
  .face .label {
    position: absolute;
    top: 18px;
    left: 22px;
    font-size: 10.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }
  .face .known-badge {
    position: absolute;
    top: 16px;
    right: 22px;
    font-size: 10.5px;
    font-weight: 600;
    background: var(--success-soft);
    color: var(--success);
    padding: 4px 10px;
    border-radius: 999px;
    display: none;
    letter-spacing: 0.04em;
  }
  .card.is-known .known-badge { display: inline-block; }
  .face.back { transform: rotateY(180deg); }
  .face .content {
    font-size: 21px;
    line-height: 1.45;
    font-weight: 450;
    max-height: 100%;
    overflow-y: auto;
    color: var(--text);
    letter-spacing: -0.005em;
  }
  .face .hint {
    position: absolute;
    bottom: 18px;
    font-size: 11.5px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  /* Controls */
  .nav {
    display: grid;
    grid-template-columns: 1fr 1.4fr 1fr;
    gap: 10px;
    margin-bottom: 12px;
  }
  .nav button {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 14px;
    border-radius: 12px;
    font-size: 14.5px;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.005em;
    transition: transform .1s, background .15s, border-color .15s;
  }
  .nav button:hover { background: var(--primary-soft); border-color: var(--primary-soft); }
  .nav button:active { transform: scale(.97); }
  .nav .flip-btn {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
    box-shadow: 0 6px 16px rgba(91,74,224,.25);
  }
  .nav .flip-btn:hover { background: var(--primary); opacity: .94; }

  .actions {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
  }
  .actions button {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 10px;
    border-radius: 10px;
    font-size: 12.5px;
    font-weight: 500;
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: background .15s, color .15s, border-color .15s;
  }
  .actions button:hover { background: var(--primary-soft); color: var(--primary); border-color: var(--primary-soft); }
  .actions .known-btn.active {
    background: var(--success-soft);
    color: var(--success);
    border-color: var(--success-soft);
  }

  .footer {
    margin-top: 22px;
    text-align: center;
    font-size: 11.5px;
    color: var(--muted);
    letter-spacing: 0.02em;
  }
  .footer b { color: var(--text); font-weight: 600; }

  @media (max-width: 420px) {
    .card, .card-stage { height: 320px; min-height: 320px; }
    .face .content { font-size: 18.5px; }
    .face { padding: 32px 22px; }
    header h1 { font-size: 19px; }
  }
</style>
</head>
<body>
<div class="app">
  <header>
    <h1 id="deck-title">Study Flashcards</h1>
    <p id="deck-subtitle">Tap the card to reveal the answer</p>
  </header>

  <div class="meta">
    <span class="pill">Card <b id="current-idx">1</b> / <b id="total-count">0</b></span>
    <span class="pill">Mastered <b id="known-count">0</b></span>
  </div>
  <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>

  <div class="card-stage">
    <div class="card" id="card" role="button" aria-label="Flip card" tabindex="0">
      <div class="face front">
        <span class="label">Question</span>
        <span class="known-badge">Mastered</span>
        <div class="content" id="front-content">Loading…</div>
        <div class="hint">Tap or press space to flip</div>
      </div>
      <div class="face back">
        <span class="label">Answer</span>
        <span class="known-badge">Mastered</span>
        <div class="content" id="back-content"></div>
        <div class="hint">Tap to flip back</div>
      </div>
    </div>
  </div>

  <div class="nav">
    <button id="prev-btn" aria-label="Previous">← Prev</button>
    <button class="flip-btn" id="flip-btn">Flip</button>
    <button id="next-btn" aria-label="Next">Next →</button>
  </div>

  <div class="actions">
    <button class="known-btn" id="known-btn">✓ Mark Known</button>
    <button id="shuffle-btn">🔀 Shuffle</button>
    <button id="reset-btn">↺ Reset</button>
  </div>

  <div class="footer">
    Keys: <b>Space</b> flip · <b>← →</b> navigate · <b>K</b> know · <b>S</b> shuffle
  </div>
</div>

<script>
/* ==============================================================
   EDIT BELOW — YOUR DECK
   ============================================================== */

const DECK_TITLE = "GRE Vocabulary — Set 1";
const DECK_SUBTITLE = "Bonus flashcards from your study guide";

const FLASHCARDS = [
  { q: "Abate",      a: "To reduce in intensity or amount; to lessen." },
  { q: "Cacophony",  a: "A harsh, discordant mixture of sounds." },
  { q: "Didactic",   a: "Intended to teach, often with a moral lesson." },
  { q: "Ephemeral",  a: "Lasting for a very short time; fleeting." },
  { q: "Fastidious", a: "Very attentive to detail; hard to please." },
  { q: "Gregarious", a: "Fond of company; sociable." },
  { q: "Iconoclast", a: "A person who attacks cherished beliefs." },
  { q: "Laconic",    a: "Using few words; concise to the point of seeming rude." },
  { q: "Mitigate",   a: "To make less severe, serious, or painful." },
  { q: "Pragmatic",  a: "Dealing with things sensibly and realistically." },
];

/* ==============================================================
   APP — typically no edits needed below
   ============================================================== */

const STORAGE_KEY = "flashcards_" + DECK_TITLE.replace(/[^a-z0-9]/gi, "_").toLowerCase();
let deck = FLASHCARDS.map((c, i) => ({ ...c, originalIdx: i }));
let currentIdx = 0;
let knownSet = new Set();

try {
  const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");
  if (Array.isArray(saved.known)) knownSet = new Set(saved.known);
} catch (e) {}

function saveProgress() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify({ known: [...knownSet] })); } catch (e) {}
}

const $ = id => document.getElementById(id);
const card = $("card"), frontContent = $("front-content"), backContent = $("back-content");
const currentIdxEl = $("current-idx"), totalCountEl = $("total-count"), knownCountEl = $("known-count");
const progressFill = $("progress-fill"), knownBtn = $("known-btn");

$("deck-title").textContent = DECK_TITLE;
$("deck-subtitle").textContent = DECK_SUBTITLE;

function render() {
  const c = deck[currentIdx];
  frontContent.textContent = c.q;
  backContent.textContent = c.a;
  card.classList.remove("flipped");
  currentIdxEl.textContent = currentIdx + 1;
  totalCountEl.textContent = deck.length;
  knownCountEl.textContent = knownSet.size;
  const k = knownSet.has(c.originalIdx);
  card.classList.toggle("is-known", k);
  knownBtn.classList.toggle("active", k);
  knownBtn.textContent = k ? "✓ Known" : "✓ Mark Known";
  progressFill.style.width = (knownSet.size / deck.length * 100).toFixed(1) + "%";
}

function flip() { card.classList.toggle("flipped"); }
function next() { currentIdx = (currentIdx + 1) % deck.length; render(); }
function prev() { currentIdx = (currentIdx - 1 + deck.length) % deck.length; render(); }
function toggleKnown() {
  const c = deck[currentIdx];
  knownSet.has(c.originalIdx) ? knownSet.delete(c.originalIdx) : knownSet.add(c.originalIdx);
  saveProgress(); render();
}
function shuffle() {
  for (let i = deck.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [deck[i], deck[j]] = [deck[j], deck[i]];
  }
  currentIdx = 0; render();
}
function resetProgress() {
  if (!confirm("Reset your 'mastered' progress for this deck?")) return;
  knownSet.clear(); saveProgress(); render();
}

card.addEventListener("click", flip);
card.addEventListener("keydown", e => { if (e.code === "Space" || e.code === "Enter") { e.preventDefault(); flip(); } });
$("flip-btn").addEventListener("click", flip);
$("next-btn").addEventListener("click", next);
$("prev-btn").addEventListener("click", prev);
$("known-btn").addEventListener("click", toggleKnown);
$("shuffle-btn").addEventListener("click", shuffle);
$("reset-btn").addEventListener("click", resetProgress);

document.addEventListener("keydown", e => {
  if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
  if (e.code === "Space") { e.preventDefault(); flip(); }
  else if (e.code === "ArrowRight") next();
  else if (e.code === "ArrowLeft") prev();
  else if (e.key === "k" || e.key === "K") toggleKnown();
  else if (e.key === "s" || e.key === "S") shuffle();
});

let touchStartX = 0;
card.addEventListener("touchstart", e => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
card.addEventListener("touchend", e => {
  const dx = e.changedTouches[0].screenX - touchStartX;
  if (Math.abs(dx) > 60) dx < 0 ? next() : prev();
}, { passive: true });

render();
</script>
</body>
</html>
